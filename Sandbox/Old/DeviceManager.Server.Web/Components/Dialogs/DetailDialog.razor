@using DummyServer.Models

<MudDialog Class="dialog-dense">
    <TitleContent>
        <MudText Typo="Typo.h6">詳細</MudText>
        <MudIconButton OnClick="OnCloseClick" Class="mud-button-close" Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
    </TitleContent>
    <DialogContent>
        <MudTable Items="rows" Class="table-edit" Breakpoint="Breakpoint.None" Dense="true" Elevation="0">
            <HeaderContent>
                <MudTh>名称</MudTh>
                <MudTh>CH</MudTh>
                <MudTh>値</MudTh>
            </HeaderContent>
            <RowTemplate Context="row">
                <MudTd>@row.Name</MudTd>
                <MudTd>@row.Channel</MudTd>
                <MudTd>@row.Value</MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="OnCloseClick" Class="btn-sm" StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Filled" Size="Size.Small">閉じる</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly List<Row> rows = [];

    [CascadingParameter]
    public required IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public required MonitorEntity Entity { get; set; }

    protected override void OnInitialized()
    {
        // TODO
        rows.Add(new Row { Name = "項目1", Value = 100.0 });
        rows.Add(new Row { Name = "項目2", Channel = 1, Value = 100.0 });
        rows.Add(new Row { Name = "項目2", Channel = 2, Value = 100.0 });
    }

    private void OnCloseClick() => MudDialog.Cancel();

    private class Row
    {
        public string Name { get; set; } = default!;

        public int? Channel { get; set; }

        public double? Value { get; set; }
    }
}
