@page "/gauge"
@inject IJSRuntime Js

<MudGrid Spacing="1">
    <MudItem xs="5">
        <canvas id="radial-gauge1" width="300" height="300">
        </canvas>
    </MudItem>
    <MudItem xs="5">
        <canvas id="radial-gauge2" width="300" height="300">
        </canvas>
    </MudItem>
    <MudItem xs="2">
        <canvas id="linear-gauge" width="100" height="300">
        </canvas>
    </MudItem>
</MudGrid>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Js.InvokeVoidAsync("initGauge");
        }
    }
}
