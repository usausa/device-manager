@page "/table"
@inject DataService DataService

<MudGrid Spacing="1">
    <MudItem xs="12">
        <MudTable Items="@list" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Status</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Level1</MudTh>
                <MudTh>Level2</MudTh>
                <MudTh>Progress1</MudTh>
                <MudTh>Progress2</MudTh>
                <MudTh>DateTime</MudTh>
                <MudTh>Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Class="mud-table-cell-align-center py-2">
                    <MudIcon Icon="@Icons.Material.Filled.TabletAndroid" Style="@($"color:{ViewHelper.StatusColor(context.Enabled)}")" Class="align-self-center"/>
                </MudTd>
                <MudTd Class="py-2">
                    <MudText>@context.Name</MudText>
                </MudTd>
                <MudTd Class="py-2">
                    <MudContainer Class="d-flex flex-row justify-content-start pa-0" Style="@($"color:{ViewHelper.WifiColor(context.Wifi)}")">
                        <MudIcon Icon="@ViewHelper.WifiIcon(context.Wifi)" Class="align-self-center mr-2"/>
                        <MudText>@($"{context.Wifi}dB")</MudText>
                    </MudContainer>
                </MudTd>
                <MudTd Class="py-2">
                    <MudContainer Class="d-flex flex-row justify-content-start pa-0" Style="@($"color:{ViewHelper.BatteryColor(context.Battery)}")">
                        <MudIcon Icon="@ViewHelper.BatteryIcon(context.Battery)" Class="align-self-center mr-2"/>
                        <MudText>@($"{context.Battery}%")</MudText>
                    </MudContainer>
                </MudTd>
                <MudTd Class="py-2">
                    <MudText Typo="Typo.caption" Align="Align.Justify">@context.Progress1</MudText>
                    <MudProgressLinear Color="Color.Info" Size="Size.Medium" Max="1000" Value="@context.Progress1"/>
                </MudTd>
                <MudTd Class="py-2">
                    <MudText Typo="Typo.caption" Align="Align.Justify">@context.Progress2</MudText>
                    <MudProgressLinear Color="Color.Tertiary" Size="Size.Medium" Max="1000" Value="@context.Progress2"/>
                </MudTd>
                <MudTd Class="py-2">
                    @context.DateTime.ToString("MM/dd HH:mm")
                </MudTd>
                <MudTd Class="py-2">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Outlined.Edit"/>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    private readonly System.Timers.Timer timer = new(200);

    private readonly Random rand = new();

    private List<StatusEntity> list = default!;

    protected override void OnInitialized()
    {
        list = DataService.QueryStatusList();

        timer.Elapsed += (_, _) => OnTimerCallback();
        timer.Start();
    }

    public void Dispose()
    {
        timer.Dispose();
    }

    private void OnTimerCallback()
    {
        var status = list[rand.Next(list.Count)];
        if (status.Enabled)
        {
            _ = InvokeAsync(() =>
            {
                switch (rand.Next(9))
                {
                    case 0:
                    case 1:
                        status.Wifi = -(30 + rand.Next(70));
                        break;
                    case 2:
                        if (status.Battery > 0)
                        {
                            status.Battery--;
                        }
                        break;
                    case 3:
                    case 4:
                    case 5:
                        status.Progress1 = status.Progress1 + rand.Next(5) + 1;
                        status.Progress1 = Math.Min(status.Progress1, 1000);
                        break;
                    case 6:
                    case 7:
                    case 8:
                        status.Progress2 = status.Progress2 + rand.Next(5) + 1;
                        status.Progress2 = Math.Min(status.Progress2, 1000);
                        break;
                }

                status.DateTime = DateTime.Now;

                StateHasChanged();
            });
        }
    }
}
