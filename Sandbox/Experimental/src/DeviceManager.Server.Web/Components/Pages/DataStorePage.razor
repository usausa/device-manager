@page "/datastore"
@rendermode InteractiveServer
@inject DataStoreService DataStoreService
@inject DeviceService DeviceService

<PageTitle>DataStore - DeviceManager</PageTitle>

<div class="page-header">
    <h1>DataStore</h1>
</div>

@if (_successMessage is not null)
{
    <div class="alert alert-success">@_successMessage</div>
}
@if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<div class="tabs">
    <button class="tab @(_activeTab == "common" ? "active" : "")" @onclick='() => SwitchTab("common")'>Common</button>
    <button class="tab @(_activeTab == "device" ? "active" : "")" @onclick='() => SwitchTab("device")'>Device-specific</button>
</div>

@if (_activeTab == "common")
{
    <div class="card">
        <div class="card-header">
            <span>Common Data Store</span>
            <button class="btn btn-primary btn-sm" @onclick="ShowAddCommon">+ Add Entry</button>
        </div>
        <div class="table-container">
            @if (_commonEntries is null)
            {
                <div class="loading"><div class="spinner"></div> Loading...</div>
            }
            else if (_commonEntries.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">&#x1F4BE;</div>
                    <p>No entries in common data store.</p>
                    <button class="btn btn-primary btn-sm" @onclick="ShowAddCommon">Add Entry</button>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Key</th>
                            <th>Value</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th style="width:140px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _commonEntries)
                        {
                            <tr>
                                <td class="mono">@entry.Key</td>
                                <td class="mono" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@entry.Value</td>
                                <td class="text-secondary">@entry.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                <td class="text-secondary">@entry.UpdatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                <td>
                                    <div class="btn-group">
                                        <button class="btn btn-outline btn-sm" @onclick="() => ShowEditCommon(entry)">Edit</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteCommonEntry(entry.Key)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@if (_activeTab == "device")
{
    <div class="toolbar">
        <div class="form-group" style="margin-bottom:0;">
            <select class="form-control" @bind="_selectedDeviceId" @bind:after="LoadDeviceEntries" style="min-width: 220px;">
                <option value="">-- Select Device --</option>
                @if (_devices is not null)
                {
                    @foreach (var d in _devices)
                    {
                        <option value="@d.DeviceId">@d.Name (@d.DeviceId)</option>
                    }
                }
            </select>
        </div>
        @if (!string.IsNullOrEmpty(_selectedDeviceId))
        {
            <button class="btn btn-primary btn-sm" @onclick="ShowAddDevice">+ Add Entry</button>
        }
    </div>

    @if (string.IsNullOrEmpty(_selectedDeviceId))
    {
        <div class="card">
            <div class="empty-state">
                <div class="empty-icon">&#x1F4F1;</div>
                <p>Select a device to view its data store.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <span>Data Store for @_selectedDeviceId</span>
                <button class="btn btn-outline btn-sm" @onclick="LoadDeviceEntries">Refresh</button>
            </div>
            <div class="table-container">
                @if (_deviceEntries is null)
                {
                    <div class="loading"><div class="spinner"></div> Loading...</div>
                }
                else if (_deviceEntries.Count == 0)
                {
                    <div class="empty-state"><p>No entries.</p></div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Value</th>
                                <th>Updated</th>
                                <th style="width:140px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in _deviceEntries)
                            {
                                <tr>
                                    <td class="mono">@entry.Key</td>
                                    <td class="mono" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@entry.Value</td>
                                    <td class="text-secondary">@entry.UpdatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-outline btn-sm" @onclick="() => ShowEditDevice(entry)">Edit</button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteDeviceEntry(entry.Key)">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}

@* Add/Edit Modal *@
@if (_showForm)
{
    <div class="modal-backdrop" @onclick="CloseForm">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(_isEditing ? "Edit Entry" : "Add Entry")</h3>
                <button class="btn btn-icon btn-outline" @onclick="CloseForm">X</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Key</label>
                    <input class="form-control" @bind="_formKey" placeholder="entry.key" disabled="@_isEditing" />
                </div>
                <div class="form-group">
                    <label>Value</label>
                    <textarea class="form-control" @bind="_formValue" placeholder="Entry value..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="CloseForm">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveEntry" disabled="@_saving">
                    @(_saving ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string _activeTab = "common";
    private List<DataStoreEntry>? _commonEntries;
    private List<DataStoreEntry>? _deviceEntries;
    private List<DeviceSummary>? _devices;
    private string _selectedDeviceId = string.Empty;

    private string? _successMessage;
    private string? _errorMessage;

    // Form state
    private bool _showForm;
    private bool _isEditing;
    private bool _isDeviceScope;
    private string _formKey = string.Empty;
    private string _formValue = string.Empty;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _devices = await DeviceService.GetAllDevicesAsync();
        await LoadCommonEntries();
    }

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        ClearMessages();
        if (tab == "common" && _commonEntries is null)
            await LoadCommonEntries();
    }

    private async Task LoadCommonEntries()
    {
        _commonEntries = await DataStoreService.GetCommonEntriesAsync();
    }

    private async Task LoadDeviceEntries()
    {
        if (string.IsNullOrEmpty(_selectedDeviceId))
        {
            _deviceEntries = null;
            return;
        }
        try
        {
            _deviceEntries = await DataStoreService.GetDeviceEntriesAsync(_selectedDeviceId);
        }
        catch
        {
            _deviceEntries = new();
        }
    }

    private void ShowAddCommon()
    {
        ClearMessages();
        _isEditing = false;
        _isDeviceScope = false;
        _formKey = string.Empty;
        _formValue = string.Empty;
        _showForm = true;
    }

    private void ShowEditCommon(DataStoreEntry entry)
    {
        ClearMessages();
        _isEditing = true;
        _isDeviceScope = false;
        _formKey = entry.Key;
        _formValue = entry.Value;
        _showForm = true;
    }

    private void ShowAddDevice()
    {
        ClearMessages();
        _isEditing = false;
        _isDeviceScope = true;
        _formKey = string.Empty;
        _formValue = string.Empty;
        _showForm = true;
    }

    private void ShowEditDevice(DataStoreEntry entry)
    {
        ClearMessages();
        _isEditing = true;
        _isDeviceScope = true;
        _formKey = entry.Key;
        _formValue = entry.Value;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task SaveEntry()
    {
        if (string.IsNullOrWhiteSpace(_formKey))
        {
            _errorMessage = "Key is required.";
            return;
        }
        _saving = true;
        ClearMessages();

        try
        {
            if (_isDeviceScope)
            {
                await DataStoreService.SetDeviceEntryAsync(_selectedDeviceId, _formKey, _formValue);
                await LoadDeviceEntries();
            }
            else
            {
                await DataStoreService.SetCommonEntryAsync(_formKey, _formValue);
                await LoadCommonEntries();
            }
            _successMessage = $"Entry '{_formKey}' saved.";
            _showForm = false;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteCommonEntry(string key)
    {
        ClearMessages();
        try
        {
            await DataStoreService.DeleteCommonEntryAsync(key);
            _successMessage = $"Entry '{key}' deleted.";
            await LoadCommonEntries();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteDeviceEntry(string key)
    {
        ClearMessages();
        try
        {
            await DataStoreService.DeleteDeviceEntryAsync(_selectedDeviceId, key);
            _successMessage = $"Entry '{key}' deleted.";
            await LoadDeviceEntries();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
    }

    private void ClearMessages()
    {
        _successMessage = null;
        _errorMessage = null;
    }
}
