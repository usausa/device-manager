@page "/devices"
@rendermode InteractiveServer
@inject DeviceService DeviceService
@inject NavigationManager Navigation

<PageTitle>Devices - DeviceManager</PageTitle>

<div class="page-header">
    <h1>Devices</h1>
    <button class="btn btn-primary" @onclick="ShowAddForm">+ Add Device</button>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (_successMessage is not null)
{
    <div class="alert alert-success">@_successMessage</div>
}

<div class="card">
    <div class="toolbar" style="padding: 1rem 1.25rem;">
        <div class="search-input">
            <input type="text" placeholder="Search devices..." @bind="_searchText" @bind:event="oninput" />
        </div>
    </div>

    <div class="table-container">
        @if (_devices is null)
        {
            <div class="loading">
                <div class="spinner"></div>
                Loading devices...
            </div>
        }
        else if (_filteredDevices!.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">&#x1F4F1;</div>
                <p>No devices found.</p>
                <button class="btn btn-primary" @onclick="ShowAddForm">Add Device</button>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Name</th>
                        <th>Group</th>
                        <th>Battery</th>
                        <th>Last Connected</th>
                        <th style="width:140px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var device in _filteredDevices)
                    {
                        <tr>
                            <td>
                                <span class="status-badge @GetStatusClass(device.Status)">
                                    <span class="status-dot @GetStatusClass(device.Status)"></span>
                                    @device.Status
                                </span>
                            </td>
                            <td>
                                <a href="/devices/@device.DeviceId">@device.Name</a>
                            </td>
                            <td>@(device.Group ?? "-")</td>
                            <td>@(device.Battery.HasValue ? $"{device.Battery}%" : "-")</td>
                            <td class="text-secondary">@FormatDate(device.LastConnectedAt)</td>
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-outline btn-sm" @onclick="() => ShowEditForm(device)">Edit</button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(device)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@* Add / Edit Modal *@
@if (_showForm)
{
    <div class="modal-backdrop" @onclick="CloseForm">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(_isEditing ? "Edit Device" : "Add Device")</h3>
                <button class="btn btn-icon btn-outline" @onclick="CloseForm">X</button>
            </div>
            <div class="modal-body">
                @if (!_isEditing)
                {
                    <div class="form-group">
                        <label>Device ID</label>
                        <input class="form-control" @bind="_formDeviceId" placeholder="unique-device-id" />
                    </div>
                    <div class="form-group">
                        <label>Platform</label>
                        <input class="form-control" @bind="_formPlatform" placeholder="Android, iOS, etc." />
                    </div>
                }
                <div class="form-group">
                    <label>Name</label>
                    <input class="form-control" @bind="_formName" placeholder="Device name" />
                </div>
                <div class="form-group">
                    <label>Group</label>
                    <input class="form-control" @bind="_formGroup" placeholder="Group name" />
                </div>
                <div class="form-group">
                    <label>Tags (comma-separated)</label>
                    <input class="form-control" @bind="_formTags" placeholder="tag1, tag2, tag3" />
                </div>
                <div class="form-group">
                    <label>Note</label>
                    <textarea class="form-control" @bind="_formNote" placeholder="Notes about this device..."></textarea>
                </div>
                @if (_isEditing)
                {
                    <div class="form-group">
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="_formIsEnabled" />
                            <span>Enabled</span>
                        </label>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="CloseForm">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveDevice" disabled="@_saving">
                    @(_saving ? "Saving..." : (_isEditing ? "Update" : "Add"))
                </button>
            </div>
        </div>
    </div>
}

@* Delete Confirmation *@
@if (_deviceToDelete is not null)
{
    <div class="modal-backdrop" @onclick="CancelDelete">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Confirm Delete</h3>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete device <strong>@_deviceToDelete.Name</strong> (@_deviceToDelete.DeviceId)?</p>
                <p class="text-secondary">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="CancelDelete">Cancel</button>
                <button class="btn btn-danger" @onclick="DeleteDevice" disabled="@_saving">
                    @(_saving ? "Deleting..." : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<DeviceSummary>? _devices;
    private string _searchText = string.Empty;
    private string? _errorMessage;
    private string? _successMessage;
    private bool _saving;

    // Form state
    private bool _showForm;
    private bool _isEditing;
    private string _editingDeviceId = string.Empty;
    private string _formDeviceId = string.Empty;
    private string _formName = string.Empty;
    private string _formPlatform = string.Empty;
    private string _formGroup = string.Empty;
    private string _formTags = string.Empty;
    private string _formNote = string.Empty;
    private bool _formIsEnabled = true;

    // Delete state
    private DeviceSummary? _deviceToDelete;

    private List<DeviceSummary>? _filteredDevices => _devices?
        .Where(d => string.IsNullOrEmpty(_searchText)
            || d.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (d.Group?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || d.DeviceId.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadDevices();
    }

    private async Task LoadDevices()
    {
        _devices = await DeviceService.GetAllDevicesAsync();
    }

    private void ShowAddForm()
    {
        _isEditing = false;
        _formDeviceId = string.Empty;
        _formName = string.Empty;
        _formPlatform = string.Empty;
        _formGroup = string.Empty;
        _formTags = string.Empty;
        _formNote = string.Empty;
        _formIsEnabled = true;
        _showForm = true;
        ClearMessages();
    }

    private async Task ShowEditForm(DeviceSummary summary)
    {
        ClearMessages();
        var detail = await DeviceService.GetDeviceAsync(summary.DeviceId);
        if (detail is null) return;

        _isEditing = true;
        _editingDeviceId = detail.DeviceId;
        _formName = detail.Name;
        _formGroup = detail.Group ?? string.Empty;
        _formTags = detail.Tags is not null ? string.Join(", ", detail.Tags) : string.Empty;
        _formNote = detail.Note ?? string.Empty;
        _formIsEnabled = detail.IsEnabled;
        _showForm = true;
    }

    private void CloseForm()
    {
        _showForm = false;
    }

    private async Task SaveDevice()
    {
        _saving = true;
        ClearMessages();

        try
        {
            if (_isEditing)
            {
                var request = new DeviceUpdateRequest
                {
                    Name = _formName,
                    Group = string.IsNullOrWhiteSpace(_formGroup) ? null : _formGroup,
                    Tags = string.IsNullOrWhiteSpace(_formTags) ? null : _formTags.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries),
                    Note = _formNote,
                    IsEnabled = _formIsEnabled
                };
                await DeviceService.UpdateDeviceAsync(_editingDeviceId, request);
                _successMessage = $"Device '{_formName}' updated successfully.";
            }
            else
            {
                if (string.IsNullOrWhiteSpace(_formDeviceId) || string.IsNullOrWhiteSpace(_formName))
                {
                    _errorMessage = "Device ID and Name are required.";
                    _saving = false;
                    return;
                }

                var registration = new DeviceRegistration
                {
                    DeviceId = _formDeviceId.Trim(),
                    Name = _formName.Trim(),
                    Platform = string.IsNullOrWhiteSpace(_formPlatform) ? null : _formPlatform.Trim(),
                    Group = string.IsNullOrWhiteSpace(_formGroup) ? null : _formGroup.Trim()
                };
                await DeviceService.RegisterDeviceAsync(registration);
                _successMessage = $"Device '{_formName}' added successfully.";
            }

            _showForm = false;
            await LoadDevices();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ConfirmDelete(DeviceSummary device)
    {
        ClearMessages();
        _deviceToDelete = device;
    }

    private void CancelDelete()
    {
        _deviceToDelete = null;
    }

    private async Task DeleteDevice()
    {
        if (_deviceToDelete is null) return;
        _saving = true;

        try
        {
            await DeviceService.DeleteDeviceAsync(_deviceToDelete.DeviceId);
            _successMessage = $"Device '{_deviceToDelete.Name}' deleted.";
            _deviceToDelete = null;
            await LoadDevices();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ClearMessages()
    {
        _errorMessage = null;
        _successMessage = null;
    }

    private static string GetStatusClass(DeviceConnectionStatus status) => status switch
    {
        DeviceConnectionStatus.Active => "active",
        DeviceConnectionStatus.Warning => "warning",
        DeviceConnectionStatus.Error => "error",
        _ => "inactive"
    };

    private static string FormatDate(DateTime? dt)
    {
        if (dt is null) return "Never";
        return dt.Value.ToLocalTime().ToString("MMM dd, HH:mm");
    }
}
