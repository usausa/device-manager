<Window x:Class="DeviceManager.TestClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DeviceManager Test Client" Height="700" Width="900"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Connection Settings -->
        <GroupBox Grid.Row="0" Header="Connection" Margin="8,8,8,4" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Server URL:"/>
                <TextBox Grid.Column="1" x:Name="ServerUrlBox" Text="https://localhost:5001"/>
                <Label Grid.Column="2" Content="Device ID:"/>
                <TextBox Grid.Column="3" x:Name="DeviceIdBox"/>
                <Label Grid.Column="4" Content="Device Name:"/>
                <TextBox Grid.Column="5" x:Name="DeviceNameBox"/>
                <Button Grid.Column="6" Content="Connect" x:Name="ConnectBtn" Click="ConnectBtn_Click"/>
                <Button Grid.Column="7" Content="Disconnect" x:Name="DisconnectBtn" Click="DisconnectBtn_Click" IsEnabled="False"/>
                <Border Grid.Column="8" x:Name="StatusIndicator" Width="16" Height="16" CornerRadius="8"
                        Background="Gray" Margin="8,0" VerticalAlignment="Center"
                        ToolTip="Disconnected"/>
            </Grid>
        </GroupBox>

        <!-- Feature Tabs -->
        <TabControl Grid.Row="1" Margin="8,4">
            <!-- Status Tab -->
            <TabItem Header="Status">
                <GroupBox Header="Send Status Report" Margin="8" Padding="8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Level:"/>
                            <TextBox Grid.Column="1" x:Name="StatusLevelBox" Text="0"/>
                            <Label Grid.Column="2" Content="Progress:"/>
                            <TextBox Grid.Column="3" x:Name="StatusProgressBox" Text="0.0"/>
                            <Label Grid.Column="4" Content="Battery:"/>
                            <TextBox Grid.Column="5" x:Name="StatusBatteryBox" Text="100"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Send Status" Click="SendStatusBtn_Click" x:Name="SendStatusBtn"/>
                            <Button Content="Start Auto-Report (30s)" Click="StartAutoReportBtn_Click" x:Name="StartAutoReportBtn"/>
                            <Button Content="Stop Auto-Report" Click="StopAutoReportBtn_Click" x:Name="StopAutoReportBtn" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </TabItem>

            <!-- Messages Tab -->
            <TabItem Header="Messages">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Send Message" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Type:"/>
                            <TextBox Grid.Column="1" x:Name="MsgTypeBox" Text="text"/>
                            <Label Grid.Column="2" Content="Content:"/>
                            <TextBox Grid.Column="3" x:Name="MsgContentBox" Text="Hello from WPF Test Client"/>
                            <Button Grid.Column="4" Content="Send" Click="SendMsgBtn_Click" x:Name="SendMsgBtn"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="Received Messages" Margin="0,8,0,0" Padding="4">
                        <ListView x:Name="MessagesListView">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time" Width="140" DisplayMemberBinding="{Binding Time}"/>
                                    <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="Content" Width="400" DisplayMemberBinding="{Binding Content}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Config Tab -->
            <TabItem Header="Config">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button Content="Refresh Config" Click="RefreshConfigBtn_Click" x:Name="RefreshConfigBtn"/>
                        <Label x:Name="ConfigStatusLabel" Content="" Foreground="Gray"/>
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="ConfigListView" Margin="0,8,0,0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Key" Width="200" DisplayMemberBinding="{Binding Key}"/>
                                <GridViewColumn Header="Value" Width="250" DisplayMemberBinding="{Binding Value}"/>
                                <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding ValueType}"/>
                                <GridViewColumn Header="Description" Width="250" DisplayMemberBinding="{Binding Description}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- DataStore Tab -->
            <TabItem Header="DataStore">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Operations" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Key:"/>
                            <TextBox Grid.Column="1" x:Name="DataKeyBox"/>
                            <Label Grid.Column="2" Content="Value:"/>
                            <TextBox Grid.Column="3" x:Name="DataValueBox"/>
                            <Button Grid.Column="4" Content="Get" Click="DataGetBtn_Click" x:Name="DataGetBtn"/>
                            <Button Grid.Column="5" Content="Set" Click="DataSetBtn_Click" x:Name="DataSetBtn"/>
                            <Button Grid.Column="6" Content="Delete" Click="DataDeleteBtn_Click" x:Name="DataDeleteBtn"/>
                            <Button Grid.Column="7" Content="Get All" Click="DataGetAllBtn_Click" x:Name="DataGetAllBtn"/>
                        </Grid>
                    </GroupBox>

                    <TextBlock Grid.Row="1" x:Name="DataResultText" Margin="4,8" TextWrapping="Wrap"
                               Foreground="DarkBlue" FontFamily="Consolas"/>

                    <GroupBox Grid.Row="2" Header="All Entries" Margin="0,4,0,0" Padding="4">
                        <ListView x:Name="DataStoreListView">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Key" Width="200" DisplayMemberBinding="{Binding Key}"/>
                                    <GridViewColumn Header="Value" Width="300" DisplayMemberBinding="{Binding Value}"/>
                                    <GridViewColumn Header="Updated" Width="160" DisplayMemberBinding="{Binding UpdatedAt}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Commands Tab -->
            <TabItem Header="Commands">
                <GroupBox Header="Received Commands" Margin="8" Padding="4">
                    <ListView x:Name="CommandsListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="140" DisplayMemberBinding="{Binding Time}"/>
                                <GridViewColumn Header="Command" Width="200" DisplayMemberBinding="{Binding Command}"/>
                                <GridViewColumn Header="Payload" Width="400" DisplayMemberBinding="{Binding Payload}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </TabItem>
        </TabControl>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                      Background="LightGray" ResizeDirection="Rows"/>

        <!-- Log Output -->
        <GroupBox Grid.Row="3" Header="Log" Margin="8,4,8,8" Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="LogBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                         TextWrapping="NoWrap" AcceptsReturn="True"/>
                <Button Grid.Column="1" Content="Clear" Click="ClearLogBtn_Click" VerticalAlignment="Top"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
