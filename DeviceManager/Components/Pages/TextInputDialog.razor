@* Reusable text input dialog *@
<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="value" Label="@Label" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">OK</MudButton>
    </DialogActions>
</MudDialog>
