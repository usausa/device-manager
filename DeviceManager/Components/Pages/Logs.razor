@page "/logs"
@rendermode InteractiveServer

<PageTitle>Logs - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
    <MudTextField @bind-Value="filterDeviceId" Placeholder="Device ID" Immediate="true"
                  Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:200px" />
    <MudSelect @bind-Value="filterLevel" Label="Min Level" Variant="Variant.Outlined" Margin="Margin.Dense"
               Style="max-width:140px" Clearable="true">
        <MudSelectItem T="int?" Value="@((int?)0)">Trace</MudSelectItem>
        <MudSelectItem T="int?" Value="@((int?)1)">Debug</MudSelectItem>
        <MudSelectItem T="int?" Value="@((int?)2)">Info</MudSelectItem>
        <MudSelectItem T="int?" Value="@((int?)3)">Warning</MudSelectItem>
        <MudSelectItem T="int?" Value="@((int?)4)">Error</MudSelectItem>
        <MudSelectItem T="int?" Value="@((int?)5)">Critical</MudSelectItem>
    </MudSelect>
    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="LoadAsync">Refresh</MudButton>
</MudStack>

<MudTable Items="logs" Dense="true" Hover="true" Elevation="1" Loading="isLoading" T="LogEntry">
    <HeaderContent>
        <MudTh Style="width:50px">Level</MudTh>
        <MudTh Style="width:120px">Device</MudTh>
        <MudTh Style="width:140px">Category</MudTh>
        <MudTh>Message</MudTh>
        <MudTh Style="width:140px">Time</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudChip T="string" Color="@GetLevelColor(context.Level)" Size="Size.Small" Style="min-width:50px">@context.Level</MudChip>
        </MudTd>
        <MudTd Style="font-family:monospace;font-size:0.75rem">@context.DeviceId</MudTd>
        <MudTd Style="font-size:0.75rem" Class="mud-text-secondary">@context.Category</MudTd>
        <MudTd Style="max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@context.Message</MudTd>
        <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText></MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4 mud-text-secondary">No log entries.</MudText>
    </NoRecordsContent>
</MudTable>
