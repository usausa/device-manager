@page "/logs"
@rendermode InteractiveServer
@inject LogService LogService

<PageTitle>Logs - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />System Logs
    </MudText>
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" OnClick="LoadLogs" />
</MudStack>

<MudCard>
    <MudCardContent Class="pa-0">
        <MudTable Items="@FilteredLogs" Hover="true" Dense="true" Elevation="0" T="LogEntry">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchText" Placeholder="Filter by device or message..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0 mr-4" Immediate="true" Style="max-width:400px" />
                <MudSelect @bind-Value="_levelFilter" Label="Level" Dense="true" Margin="Margin.Dense"
                           Style="max-width:160px" Clearable="true">
                    <MudSelectItem Value="@((int?)2)">Information</MudSelectItem>
                    <MudSelectItem Value="@((int?)3)">Warning</MudSelectItem>
                    <MudSelectItem Value="@((int?)4)">Error</MudSelectItem>
                    <MudSelectItem Value="@((int?)1)">Debug</MudSelectItem>
                    <MudSelectItem Value="@((int?)0)">Trace</MudSelectItem>
                </MudSelect>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Timestamp</MudTh>
                <MudTh>Level</MudTh>
                <MudTh>Device</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Message</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Timestamp">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="white-space:nowrap">
                        @context.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Level">
                    <MudChip T="string" Color="@GetLevelColor(context.Level)" Size="Size.Small" Variant="Variant.Filled">
                        @context.Level
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Device">
                    <MudLink Href="@($"/devices/{context.DeviceId}")" Typo="Typo.body2">@context.DeviceId</MudLink>
                </MudTd>
                <MudTd DataLabel="Category">
                    <MudText Typo="Typo.body2" Style="font-family:monospace">@context.Category</MudText>
                </MudTd>
                <MudTd DataLabel="Message">@context.Message</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4 mud-text-secondary">No logs found.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    private List<LogEntry>? _logs;
    private string _searchText = string.Empty;
    private int? _levelFilter;

    private IEnumerable<LogEntry> FilteredLogs => _logs?
        .Where(l =>
            (string.IsNullOrEmpty(_searchText)
                || l.DeviceId.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || l.Message.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
            && (_levelFilter is null || (int)l.Level == _levelFilter))
        ?? [];

    protected override async Task OnInitializedAsync() => await LoadLogs();

    private async Task LoadLogs()
    {
        try { _logs = await LogService.GetLogsAsync(null, null, 0, 500); }
        catch { _logs = []; }
    }

    private static Color GetLevelColor(Shared.Models.LogLevel level) => level switch
    {
        Shared.Models.LogLevel.Information => Color.Info,
        Shared.Models.LogLevel.Warning => Color.Warning,
        Shared.Models.LogLevel.Error or Shared.Models.LogLevel.Critical => Color.Error,
        _ => Color.Default
    };
}
