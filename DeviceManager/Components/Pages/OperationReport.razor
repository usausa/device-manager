@page "/operation-report"
@rendermode InteractiveServer

<PageTitle>Operation Report - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
    <MudSelect @bind-Value="selectedDeviceId" Label="Device" Variant="Variant.Outlined"
               Margin="Margin.Dense" Style="max-width:280px" Clearable="true">
        @foreach (var d in allDevices)
        {
            <MudSelectItem Value="@d.DeviceId">@d.Name (@d.DeviceId)</MudSelectItem>
        }
    </MudSelect>
    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="LoadReportAsync">Load</MudButton>
</MudStack>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (device is not null)
{
    <MudGrid Spacing="1" Class="mb-2">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Device Info</MudText>
                <MudSimpleTable Dense="true" Elevation="0">
                    <tbody>
                        <tr><td class="mud-text-secondary">Name</td><td>@device.Name</td></tr>
                        <tr><td class="mud-text-secondary">Platform</td><td>@(device.Platform ?? "-")</td></tr>
                        <tr><td class="mud-text-secondary">Group</td><td>@(device.Group ?? "-")</td></tr>
                        <tr><td class="mud-text-secondary">Status</td>
                            <td><MudIcon Icon="@Icons.Material.Filled.Circle" Color="@GetStatusColor(device.Status)" Size="Size.Small" /> @device.Status</td>
                        </tr>
                        <tr><td class="mud-text-secondary">Last Seen</td><td>@(device.LastConnectedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Uptime Summary</MudText>
                <MudSimpleTable Dense="true" Elevation="0">
                    <tbody>
                        <tr><td class="mud-text-secondary">Total Connections</td><td>@totalConnections</td></tr>
                        <tr><td class="mud-text-secondary">Est. Uptime</td><td>@FormatUptime(estimatedUptime)</td></tr>
                        <tr><td class="mud-text-secondary">Avg CPU</td><td>@(avgCpu.HasValue ? $"{avgCpu:0.1}%" : "-")</td></tr>
                        <tr><td class="mud-text-secondary">Avg Memory</td><td>@(avgMemory.HasValue ? $"{avgMemory:0.1}%" : "-")</td></tr>
                        <tr><td class="mud-text-secondary">Avg Battery</td><td>@(avgBattery.HasValue ? $"{avgBattery:0}%" : "-")</td></tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            @if (device.CpuUsage.HasValue || device.MemoryUsage.HasValue || device.Battery.HasValue)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Current State</MudText>
                    @if (device.CpuUsage.HasValue)
                    {
                        <MudText Typo="Typo.caption">CPU @($"{device.CpuUsage:0.1}%")</MudText>
                        <MudProgressLinear Value="device.CpuUsage.Value" Max="100" Color="@GetUsageColor(device.CpuUsage.Value)" Class="mb-2" Style="height:8px" />
                    }
                    @if (device.MemoryUsage.HasValue)
                    {
                        <MudText Typo="Typo.caption">Memory @($"{device.MemoryUsage:0.1}%")</MudText>
                        <MudProgressLinear Value="device.MemoryUsage.Value" Max="100" Color="@GetUsageColor(device.MemoryUsage.Value)" Class="mb-2" Style="height:8px" />
                    }
                    @if (device.Battery.HasValue)
                    {
                        <MudText Typo="Typo.caption">Battery @($"{device.Battery}%")</MudText>
                        <MudProgressLinear Value="device.Battery.Value" Max="100" Color="@GetBatteryColor(device.Battery.Value)" Style="height:8px" />
                    }
                </MudPaper>
            }
        </MudItem>
    </MudGrid>

    @if (statusHistory.Count > 0)
    {
        <MudPaper Class="pa-2 mb-2" Elevation="1">
            <MudText Typo="Typo.subtitle2" Class="mb-1 pa-1">Status History (last @statusHistory.Count records)</MudText>
            <MudTable Items="statusHistory" Dense="true" Hover="true" Elevation="0" T="DeviceStatusReport">
                <HeaderContent>
                    <MudTh Style="width:140px">Time</MudTh>
                    <MudTh Style="width:80px">CPU %</MudTh>
                    <MudTh Style="width:80px">MEM %</MudTh>
                    <MudTh Style="width:80px">Battery</MudTh>
                    <MudTh>Progress1</MudTh>
                    <MudTh>Progress2</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText></MudTd>
                    <MudTd>@if (context.CpuUsage.HasValue) { <MudText Typo="Typo.body2" Color="@GetUsageColor(context.CpuUsage.Value)">@($"{context.CpuUsage:0.1}%")</MudText> }</MudTd>
                    <MudTd>@if (context.MemoryUsage.HasValue) { <MudText Typo="Typo.body2" Color="@GetUsageColor(context.MemoryUsage.Value)">@($"{context.MemoryUsage:0.1}%")</MudText> }</MudTd>
                    <MudTd>@if (context.Battery.HasValue) { <MudText Typo="Typo.body2">@($"{context.Battery}%")</MudText> }</MudTd>
                    <MudTd>@if (context.Progress1.HasValue) { <MudProgressLinear Value="context.Progress1.Value" Max="100" Color="Color.Primary" Style="min-width:60px;height:6px" /> }</MudTd>
                    <MudTd>@if (context.Progress2.HasValue) { <MudProgressLinear Value="context.Progress2.Value" Max="100" Color="Color.Secondary" Style="min-width:60px;height:6px" /> }</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <MudPaper Class="pa-2" Elevation="1">
        <MudText Typo="Typo.subtitle2" Class="mb-1 pa-1">Connection Log</MudText>
        <MudTable Items="connectionLog" Dense="true" Hover="true" Elevation="0" T="ConnectionEvent">
            <HeaderContent>
                <MudTh Style="width:40px">Event</MudTh>
                <MudTh>Time</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudIcon Icon="@(context.Connected ? Icons.Material.Filled.Login : Icons.Material.Filled.Logout)"
                             Color="@(context.Connected ? Color.Success : Color.Default)"
                             Size="Size.Small" />
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</MudText>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4 mud-text-secondary">No connection log.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}
