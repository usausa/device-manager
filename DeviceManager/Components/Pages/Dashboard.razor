@page "/"
@rendermode InteractiveServer

<PageTitle>Dashboard - DeviceManager</PageTitle>

@if (summary is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid Spacing="1" Class="mb-2">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 summary-card-primary">
                <div class="d-flex align-center gap-1 mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Devices" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Total</MudText>
                </div>
                <MudText Typo="Typo.h5" Align="Align.Center">@summary.Total</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 summary-card-success">
                <div class="d-flex align-center gap-1 mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Active</MudText>
                </div>
                <MudText Typo="Typo.h5" Color="Color.Success" Align="Align.Center">@summary.Active</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 summary-card-warning">
                <div class="d-flex align-center gap-1 mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Warning</MudText>
                </div>
                <MudText Typo="Typo.h5" Color="Color.Warning" Align="Align.Center">@summary.Warning</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 summary-card-error">
                <div class="d-flex align-center gap-1 mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Error</MudText>
                </div>
                <MudText Typo="Typo.h5" Color="Color.Error" Align="Align.Center">@summary.Error</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTable Items="FilteredDevices" Dense="true" Hover="true" Elevation="1"
              Filter="DeviceFilter" T="DeviceSummary"
              OnRowClick="row => NavigateToDevice(row.Item!.DeviceId)">
        <ToolBarContent>
            <MudTextField @bind-Value="searchText" Placeholder="Search..." Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Small" Margin="Margin.Dense" Class="mt-0" Style="max-width:300px" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="ShowAddDialog">Add Device</MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width:36px"></MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Group</MudTh>
            @if (Options.ShowWifi)   { <MudTh Style="width:80px"><MudIcon Icon="@Icons.Material.Filled.Wifi" Size="Size.Small" /></MudTh> }
            @if (Options.ShowBattery){ <MudTh Style="width:80px"><MudIcon Icon="@Icons.Material.Filled.BatteryFull" Size="Size.Small" /></MudTh> }
            @if (Options.ShowCpu)    { <MudTh Style="width:70px">CPU</MudTh> }
            @if (Options.ShowMemory) { <MudTh Style="width:70px">MEM</MudTh> }
            @if (Options.ShowProgress1){ <MudTh Style="min-width:80px">Progress1</MudTh> }
            @if (Options.ShowProgress2){ <MudTh Style="min-width:80px">Progress2</MudTh> }
            @if (Options.ShowGps)    { <MudTh Style="width:130px">GPS</MudTh> }
            <MudTh>Last Connected</MudTh>
            <MudTh Style="width:120px"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Color="@GetStatusColor(context.Status)" Size="Size.Small" />
            </MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Group">@(context.Group ?? "-")</MudTd>
            @if (Options.ShowWifi)
            {
                <MudTd DataLabel="WiFi">
                    @if (context.WifiRssi.HasValue)
                    {
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@GetWifiIcon(context.WifiRssi.Value)" Size="Size.Small" Color="@GetWifiColor(context.WifiRssi.Value)" />
                            <MudText Typo="Typo.body2" Color="@GetWifiColor(context.WifiRssi.Value)">@context.WifiRssi</MudText>
                        </div>
                    }
                </MudTd>
            }
            @if (Options.ShowBattery)
            {
                <MudTd DataLabel="Battery">
                    @if (context.Battery.HasValue)
                    {
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@GetBatteryIcon(context.Battery.Value)" Size="Size.Small" Color="@GetBatteryColor(context.Battery.Value)" />
                            <MudText Typo="Typo.body2" Color="@GetBatteryColor(context.Battery.Value)">@context.Battery%</MudText>
                        </div>
                    }
                </MudTd>
            }
            @if (Options.ShowCpu)
            {
                <MudTd DataLabel="CPU">
                    @if (context.CpuUsage.HasValue)
                    {
                        <MudTooltip Text="@($"{context.CpuUsage:0.0}%")">
                            <MudProgressLinear Value="context.CpuUsage.Value" Max="100"
                                               Color="@GetUsageColor(context.CpuUsage.Value)"
                                               Style="min-width:50px;height:6px" />
                        </MudTooltip>
                    }
                </MudTd>
            }
            @if (Options.ShowMemory)
            {
                <MudTd DataLabel="Memory">
                    @if (context.MemoryUsage.HasValue)
                    {
                        <MudTooltip Text="@($"{context.MemoryUsage:0.0}%")">
                            <MudProgressLinear Value="context.MemoryUsage.Value" Max="100"
                                               Color="@GetUsageColor(context.MemoryUsage.Value)"
                                               Style="min-width:50px;height:6px" />
                        </MudTooltip>
                    }
                </MudTd>
            }
            @if (Options.ShowProgress1)
            {
                <MudTd DataLabel="Progress1">
                    @if (context.Progress1.HasValue)
                    {
                        <MudProgressLinear Value="context.Progress1.Value" Max="100" Color="Color.Primary"
                                           Style="min-width:60px;height:6px" />
                    }
                    else
                    {
                        <MudProgressLinear Value="context.Progress" Max="100" Color="Color.Primary"
                                           Style="min-width:60px;height:6px" />
                    }
                </MudTd>
            }
            @if (Options.ShowProgress2)
            {
                <MudTd DataLabel="Progress2">
                    @if (context.Progress2.HasValue)
                    {
                        <MudProgressLinear Value="context.Progress2.Value" Max="100" Color="Color.Secondary"
                                           Style="min-width:60px;height:6px" />
                    }
                </MudTd>
            }
            @if (Options.ShowGps)
            {
                <MudTd DataLabel="GPS">
                    @if (context.Latitude.HasValue && context.Longitude.HasValue)
                    {
                        <MudTooltip Text="@($"{context.Latitude:0.000000}, {context.Longitude:0.000000}")">
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Info" />
                                <MudText Typo="Typo.caption">@($"{context.Latitude:0.00},{context.Longitude:0.00}")</MudText>
                            </div>
                        </MudTooltip>
                    }
                </MudTd>
            }
            <MudTd DataLabel="Last Connected">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@FormatDateTime(context.LastConnectedAt)</MudText>
            </MudTd>
            <MudTd @onclick:stopPropagation="true">
                <MudTooltip Text="Take Screenshot">
                    <MudIconButton Icon="@Icons.Material.Filled.Screenshot" Size="Size.Small"
                                   Color="@(pendingScreenshot.ContainsKey(context.DeviceId) ? Color.Warning : Color.Default)"
                                   OnClick="() => RequestScreenshotAsync(context)" />
                </MudTooltip>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="() => ShowEditDialogAsync(context.DeviceId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="() => ConfirmDeleteAsync(context)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4 mud-text-secondary">No devices.</MudText>
        </NoRecordsContent>
    </MudTable>
}
