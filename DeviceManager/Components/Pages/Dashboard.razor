@page "/"
@rendermode InteractiveServer
@inject DeviceService DeviceService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Dashboard - DeviceManager</PageTitle>

<div class="page-header">
    <h1>📊 Dashboard</h1>
</div>

@if (summary is null)
{
    <div class="loading"><div class="spinner"></div> Loading dashboard...</div>
}
else
{
    <div class="stats-grid mb-3">
        <div class="stat-card">
            <div class="stat-value">@summary.Total</div>
            <div class="stat-label">Total Devices</div>
        </div>
        <div class="stat-card active">
            <div class="stat-value">@summary.Active</div>
            <div class="stat-label">Active</div>
        </div>
        <div class="stat-card warning">
            <div class="stat-value">@summary.Warning</div>
            <div class="stat-label">Warning</div>
        </div>
        <div class="stat-card error">
            <div class="stat-value">@summary.Error</div>
            <div class="stat-label">Error</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@summary.Inactive</div>
            <div class="stat-label">Inactive</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span>Recent Devices</span>
            <a href="/devices" class="btn btn-outline btn-sm">View All →</a>
        </div>
        <div class="toolbar" style="padding: 0.75rem 1.25rem;">
            <div class="search-input">
                <input type="text" placeholder="Search devices..." @bind="searchText" @bind:event="oninput" />
            </div>
        </div>
        <div class="table-container">
            @if (devices is null)
            {
                <div class="loading"><div class="spinner"></div> Loading...</div>
            }
            else if (filteredDevices!.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">📱</div>
                    <p>No devices registered yet.</p>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Name</th>
                            <th>Group</th>
                            <th>Battery</th>
                            <th>Last Connected</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in filteredDevices.Take(20))
                        {
                            <tr style="cursor:pointer" @onclick="() => NavigateToDevice(device.DeviceId)">
                                <td>
                                    <span class="status-badge @GetStatusClass(device.Status)">
                                        <span class="status-dot @GetStatusClass(device.Status)"></span>
                                        @device.Status
                                    </span>
                                </td>
                                <td>@device.Name</td>
                                <td>@(device.Group ?? "-")</td>
                                <td>@(device.Battery.HasValue ? $"{device.Battery}%" : "-")</td>
                                <td class="text-secondary">@FormatDateTime(device.LastConnectedAt)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private StatusSummary? summary;
    private List<DeviceSummary>? devices;
    private string searchText = string.Empty;
    private HubConnection? hubConnection;

    private List<DeviceSummary>? filteredDevices => devices?
        .Where(d => string.IsNullOrEmpty(searchText)
            || d.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
            || (d.Group?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || d.DeviceId.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await StartSignalR();
    }

    private async Task LoadData()
    {
        summary = await DeviceService.GetStatusSummaryAsync();
        devices = await DeviceService.GetAllDevicesAsync();
    }

    private async Task StartSignalR()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri(HubConstants.DeviceHubPath))
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<string>(HubConstants.DashboardMethods.DeviceConnected, async _ =>
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<string>(HubConstants.DashboardMethods.DeviceDisconnected, async _ =>
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<string>(HubConstants.DashboardMethods.DeviceStatusUpdated, async _ =>
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("JoinGroup", HubConstants.Groups.Dashboard);
        }
        catch
        {
            // SignalR connection failure is non-fatal for the dashboard
        }
    }

    private void NavigateToDevice(string deviceId)
    {
        Navigation.NavigateTo($"/devices/{deviceId}");
    }

    private static string GetStatusClass(DeviceConnectionStatus status) => status switch
    {
        DeviceConnectionStatus.Active => "active",
        DeviceConnectionStatus.Warning => "warning",
        DeviceConnectionStatus.Error => "error",
        _ => "inactive"
    };

    private static string FormatDateTime(DateTime? dt)
    {
        if (dt is null) return "Never";
        var local = dt.Value.ToLocalTime();
        var diff = DateTime.Now - local;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return local.ToString("MMM dd, HH:mm");
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
