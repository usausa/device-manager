@page "/"
@rendermode InteractiveServer

<PageTitle>Dashboard - DeviceManager</PageTitle>

@if (summary is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid Spacing="1" Class="mb-2">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-2 d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Devices" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.caption">Total</MudText>
                    <MudText Typo="Typo.h6">@summary.Total</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-2 d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <div>
                    <MudText Typo="Typo.caption">Active</MudText>
                    <MudText Typo="Typo.h6">@summary.Active</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-2 d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                <div>
                    <MudText Typo="Typo.caption">Warning</MudText>
                    <MudText Typo="Typo.h6">@summary.Warning</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-2 d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" />
                <div>
                    <MudText Typo="Typo.caption">Error</MudText>
                    <MudText Typo="Typo.h6">@summary.Error</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTable Items="FilteredDevices" Dense="true" Hover="true" Elevation="1"
              QuickFilter="DeviceFilter" T="DeviceSummary"
              OnRowClick="row => NavigateToDevice(row.Item!.DeviceId)">
        <ToolBarContent>
            <MudTextField @bind-Value="searchText" Placeholder="Search..." Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Small" Class="mt-0" Style="max-width:300px" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="ShowAddDialog">Add Device</MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width:36px"></MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Group</MudTh>
            <MudTh Style="width:40px"><MudIcon Icon="@Icons.Material.Filled.Wifi" Size="Size.Small" /></MudTh>
            <MudTh Style="width:40px"><MudIcon Icon="@Icons.Material.Filled.BatteryFull" Size="Size.Small" /></MudTh>
            <MudTh>Progress</MudTh>
            <MudTh>Last Connected</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@GetStatusIcon(context.Status)" Color="@GetStatusColor(context.Status)" Size="Size.Small" />
            </MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Group">@(context.Group ?? "-")</MudTd>
            <MudTd DataLabel="WiFi">
                @if (context.WifiRssi.HasValue)
                {
                    <MudText Typo="Typo.body2" Style="@GetWifiStyle(context.WifiRssi.Value)">@context.WifiRssi dBm</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Battery">
                @if (context.Battery.HasValue)
                {
                    <MudText Typo="Typo.body2" Style="@GetBatteryStyle(context.Battery.Value)">@context.Battery%</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Progress">
                @if (context.ProgressValues is { Count: > 0 })
                {
                    @foreach (var kv in context.ProgressValues)
                    {
                        <MudTooltip Text="@kv.Key">
                            <MudProgressLinear Value="kv.Value" Max="100" Color="Color.Primary"
                                               Style="min-width:60px;height:6px" Class="my-1" />
                        </MudTooltip>
                    }
                }
                else
                {
                    <MudProgressLinear Value="context.Progress" Max="100" Color="Color.Primary"
                                       Style="min-width:60px;height:6px" />
                }
            </MudTd>
            <MudTd DataLabel="Last Connected">
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@FormatDateTime(context.LastConnectedAt)</MudText>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4 mud-text-secondary">No devices.</MudText>
        </NoRecordsContent>
    </MudTable>
}
