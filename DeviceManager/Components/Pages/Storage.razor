@page "/storage"
@page "/storage/{*SubPath}"
@rendermode InteractiveServer

<PageTitle>Storage - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
    <MudBreadcrumbs Items="breadcrumbs" Class="pa-0" />
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.CreateNewFolder" OnClick="ShowNewFolderDialogAsync">New Folder</MudButton>
    <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadFilesAsync" MaximumFileCount="20">
        <CustomContent>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Upload" OnClick="@context.OpenFilePickerAsync">Upload</MudButton>
        </CustomContent>
    </MudFileUpload>
</MudStack>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="entries" Dense="true" Hover="true" Elevation="1" T="StorageEntry"
              OnRowClick="row => OnRowClickAsync(row.Item!)">
        <HeaderContent>
            <MudTh Style="width:36px"></MudTh>
            <MudTh>Name</MudTh>
            <MudTh Style="width:100px">Size</MudTh>
            <MudTh Style="width:150px">Modified</MudTh>
            <MudTh Style="width:80px"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@(context.IsDirectory ? Icons.Material.Filled.Folder : Icons.Material.Filled.InsertDriveFile)"
                         Color="@(context.IsDirectory ? Color.Warning : Color.Default)" Size="Size.Small" />
            </MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@(context.IsDirectory ? "" : FormatSize(context.Length))</MudText></MudTd>
            <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.LastModified?.ToLocalTime().ToString("MM/dd HH:mm")</MudText></MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="() => DeleteAsync(context)" />
                @if (!context.IsDirectory)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                   Href="@GetDownloadUrl(context)" Target="_blank" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4 mud-text-secondary">Empty folder.</MudText>
        </NoRecordsContent>
    </MudTable>
}
