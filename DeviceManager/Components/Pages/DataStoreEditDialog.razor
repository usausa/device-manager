@* DataStore entry add/edit dialog *@
<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="key" Label="Key" Required="true" Disabled="!IsNew"
                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
        <MudTextField @bind-Value="value" Label="Value" Required="true" Lines="4"
                      Variant="Variant.Outlined" Margin="Margin.Dense" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>
