@page "/devices/{DeviceId}"
@rendermode InteractiveServer

<PageTitle>@(device?.Name ?? "Device") - DeviceManager</PageTitle>

@if (device is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" OnClick="GoBack" />
        <MudText Typo="Typo.h6">@device.Name</MudText>
        <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Color="@Dashboard.GetStatusColor(device.Status)" Size="Size.Small" />
    </MudStack>

    <MudGrid Spacing="1" Class="mb-2">
        <MudItem xs="12" md="5">
            <MudSimpleTable Dense="true" Elevation="1">
                <tbody>
                    <tr><td class="mud-text-secondary">Device ID</td><td style="font-family:monospace">@device.DeviceId</td></tr>
                    <tr><td class="mud-text-secondary">Platform</td><td>@(device.Platform ?? "-")</td></tr>
                    <tr><td class="mud-text-secondary">Group</td><td>@(device.Group ?? "-")</td></tr>
                    <tr><td class="mud-text-secondary">Enabled</td><td><MudIcon Icon="@(device.IsEnabled ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" Color="@(device.IsEnabled ? Color.Success : Color.Error)" Size="Size.Small" /></td></tr>
                    @if (device.Battery.HasValue)
                    {
                        <tr><td class="mud-text-secondary">Battery</td><td><MudIcon Icon="@Dashboard.GetBatteryIcon(device.Battery.Value)" Color="@Dashboard.GetBatteryColor(device.Battery.Value)" Size="Size.Small" /> @device.Battery%</td></tr>
                    }
                    @if (device.WifiRssi.HasValue)
                    {
                        <tr><td class="mud-text-secondary">WiFi</td><td><MudIcon Icon="@Dashboard.GetWifiIcon(device.WifiRssi.Value)" Color="@Dashboard.GetWifiColor(device.WifiRssi.Value)" Size="Size.Small" /> @device.WifiRssi dBm</td></tr>
                    }
                    <tr><td class="mud-text-secondary">Registered</td><td>@device.RegisteredAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td></tr>
                    <tr><td class="mud-text-secondary">Last Connected</td><td>@(device.LastConnectedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudItem>
        <MudItem xs="12" md="7">
            @if (device.ProgressValues is { Count: > 0 })
            {
                <MudPaper Class="pa-2" Elevation="1">
                    @foreach (var kv in device.ProgressValues)
                    {
                        <MudText Typo="Typo.caption">@kv.Key (@kv.Value.ToString("0.0")%)</MudText>
                        <MudProgressLinear Value="kv.Value" Max="100" Color="Color.Primary" Class="mb-1" Style="height:8px" />
                    }
                </MudPaper>
            }
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2"
             ActivePanelIndexChanged="OnTabChanged">
        <MudTabPanel Text="History" Icon="@Icons.Material.Filled.BarChart">
            @if (statusHistory is not null)
            {
                <MudTable Items="statusHistory.Take(50)" Dense="true" Hover="true" Elevation="0" T="DeviceStatusReport">
                    <HeaderContent>
                        <MudTh>Time</MudTh><MudTh>Level</MudTh><MudTh>Progress</MudTh><MudTh>Battery</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText></MudTd>
                        <MudTd>@context.Level</MudTd>
                        <MudTd><MudProgressLinear Value="context.Progress" Max="100" Color="Color.Primary" Style="width:80px;height:6px" /></MudTd>
                        <MudTd>@(context.Battery.HasValue ? $"{context.Battery}%" : "-")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
        <MudTabPanel Text="Messages" Icon="@Icons.Material.Filled.Message">
            @if (messages is not null)
            {
                <MudTable Items="messages" Dense="true" Hover="true" Elevation="0" T="ServerMessage">
                    <HeaderContent>
                        <MudTh>Dir</MudTh><MudTh>Type</MudTh><MudTh>Content</MudTh><MudTh>Time</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@(context.Direction == MessageDirection.ServerToDevice ? "→" : "←")</MudTd>
                        <MudTd Style="font-family:monospace">@context.MessageType</MudTd>
                        <MudTd Style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@context.Content</MudTd>
                        <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
        <MudTabPanel Text="Config" Icon="@Icons.Material.Filled.Tune">
            @if (resolvedConfig is not null)
            {
                <MudTable Items="resolvedConfig" Dense="true" Hover="true" Elevation="0" T="ConfigEntry">
                    <HeaderContent>
                        <MudTh>Key</MudTh><MudTh>Value</MudTh><MudTh>Type</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="font-family:monospace">@context.Key</MudTd>
                        <MudTd Style="font-family:monospace">@context.Value</MudTd>
                        <MudTd>@context.ValueType</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
        <MudTabPanel Text="DataStore" Icon="@Icons.Material.Filled.Storage">
            @if (dataEntries is not null)
            {
                <MudTable Items="dataEntries" Dense="true" Hover="true" Elevation="0" T="DataStoreEntry">
                    <HeaderContent>
                        <MudTh>Key</MudTh><MudTh>Value</MudTh><MudTh>Updated</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="font-family:monospace">@context.Key</MudTd>
                        <MudTd Style="font-family:monospace;max-width:300px;overflow:hidden;text-overflow:ellipsis">@context.Value</MudTd>
                        <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.UpdatedAt.ToLocalTime().ToString("MM/dd HH:mm")</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>
    </MudTabs>
}
