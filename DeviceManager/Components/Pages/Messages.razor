@page "/messages"
@rendermode InteractiveServer

<PageTitle>Messages - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
    <MudTextField @bind-Value="filterDeviceId" Placeholder="Filter by Device ID" Immediate="true"
                  Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:250px"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList" IconSize="Size.Small" />
    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="LoadAsync">Refresh</MudButton>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Send" OnClick="ShowSendDialogAsync">Send Message</MudButton>
</MudStack>

<MudTable Items="messages" Dense="true" Hover="true" Elevation="1" Loading="isLoading" T="ServerMessage">
    <HeaderContent>
        <MudTh>Direction</MudTh>
        <MudTh>Device</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Content</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Time</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><MudIcon Icon="@(context.Direction == MessageDirection.ServerToDevice ? Icons.Material.Filled.CallMade : Icons.Material.Filled.CallReceived)" Size="Size.Small" /></MudTd>
        <MudTd Style="font-family:monospace;font-size:0.75rem">@(context.DeviceId ?? "*")</MudTd>
        <MudTd Style="font-family:monospace">@context.MessageType</MudTd>
        <MudTd Style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@context.Content</MudTd>
        <MudTd>@context.Status</MudTd>
        <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm:ss")</MudText></MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4 mud-text-secondary">No messages.</MudText>
    </NoRecordsContent>
</MudTable>
