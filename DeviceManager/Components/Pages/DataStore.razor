@page "/datastore"
@rendermode InteractiveServer
@inject DataStoreService DataStoreService

<PageTitle>Data Store - DeviceManager</PageTitle>

<div class="page-header">
    <h1>💾 Data Store</h1>
    <button class="btn btn-outline" @onclick="LoadEntries">Refresh</button>
</div>

<div class="card">
    <div class="toolbar" style="padding: 1rem 1.25rem;">
        <div class="search-input">
            <input type="text" placeholder="Filter by key..." @bind="searchText" @bind:event="oninput" />
        </div>
    </div>
    <div class="table-container">
        @if (entries is null)
        {
            <div class="loading"><div class="spinner"></div> Loading data store...</div>
        }
        else if (filteredEntries!.Count == 0)
        {
            <div class="empty-state"><div class="empty-icon">💾</div><p>No data store entries.</p></div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Value</th>
                        <th>Updated</th>
                        <th style="width:80px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in filteredEntries)
                    {
                        <tr>
                            <td class="mono">@e.Key</td>
                            <td class="mono" style="max-width:400px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@e.Value">@e.Value</td>
                            <td class="text-secondary">@e.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteEntry(e)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<DataStoreEntry>? entries;
    private string searchText = string.Empty;

    private List<DataStoreEntry>? filteredEntries => entries?
        .Where(e => string.IsNullOrEmpty(searchText)
            || e.Key.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync() => await LoadEntries();

    private async Task LoadEntries()
    {
        try { entries = await DataStoreService.GetCommonEntriesAsync(); }
        catch { entries = []; }
    }

    private async Task DeleteEntry(DataStoreEntry entry)
    {
        await DataStoreService.DeleteCommonEntryAsync(entry.Key);
        await LoadEntries();
    }
}
