@page "/datastore"
@rendermode InteractiveServer

<PageTitle>DataStore - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
    <MudTextField @bind-Value="searchText" Placeholder="Search..." Immediate="true"
                  Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:250px"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" />
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Add" OnClick="ShowAddDialogAsync">Add Entry</MudButton>
</MudStack>

<MudTable Items="FilteredEntries" Dense="true" Hover="true" Elevation="1" Loading="isLoading" T="DataStoreEntry">
    <HeaderContent>
        <MudTh>Key</MudTh>
        <MudTh>Value</MudTh>
        <MudTh Style="width:150px">Updated</MudTh>
        <MudTh Style="width:100px"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd Style="font-family:monospace">@context.Key</MudTd>
        <MudTd Style="font-family:monospace;max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@context.Value</MudTd>
        <MudTd><MudText Typo="Typo.body2" Class="mud-text-secondary">@context.UpdatedAt.ToLocalTime().ToString("MM/dd HH:mm")</MudText></MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="() => ShowEditDialogAsync(context)" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteAsync(context)" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Class="pa-4 mud-text-secondary">No entries.</MudText>
    </NoRecordsContent>
</MudTable>
