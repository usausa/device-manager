@page "/datastore"
@rendermode InteractiveServer
@inject DataStoreService DataStoreService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Data Store - DeviceManager</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h5">
        <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />Data Store
    </MudText>
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" OnClick="LoadEntries" />
</MudStack>

<MudCard>
    <MudCardContent Class="pa-0">
        <MudTable Items="@FilteredEntries" Hover="true" Dense="true" Elevation="0"
                  QuickFilter="FilterEntry" T="DataStoreEntry">
            <ToolBarContent>
                <MudTextField @bind-Value="_searchText" Placeholder="Filter by key..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" Immediate="true" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Key</MudTh>
                <MudTh>Value</MudTh>
                <MudTh>Updated</MudTh>
                <MudTh Style="width:80px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Key">
                    <MudText Typo="Typo.body2" Style="font-family:monospace">@context.Key</MudText>
                </MudTd>
                <MudTd DataLabel="Value" Style="max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    <MudText Typo="Typo.body2" Style="font-family:monospace" title="@context.Value">@context.Value</MudText>
                </MudTd>
                <MudTd DataLabel="Updated">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        @context.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="() => ConfirmDelete(context)" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4 mud-text-secondary">No data store entries.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    private List<DataStoreEntry>? _entries;
    private string _searchText = string.Empty;

    private IEnumerable<DataStoreEntry> FilteredEntries => _entries ?? [];

    private bool FilterEntry(DataStoreEntry e) =>
        string.IsNullOrEmpty(_searchText)
        || e.Key.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync() => await LoadEntries();

    private async Task LoadEntries()
    {
        try { _entries = await DataStoreService.GetCommonEntriesAsync(); }
        catch { _entries = []; }
    }

    private async Task ConfirmDelete(DataStoreEntry entry)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete", $"Delete entry '{entry.Key}'?",
            yesText: "Delete", cancelText: "Cancel");

        if (result is true) await DeleteEntry(entry);
    }

    private async Task DeleteEntry(DataStoreEntry entry)
    {
        try
        {
            await DataStoreService.DeleteCommonEntryAsync(entry.Key);
            Snackbar.Add($"Deleted '{entry.Key}'.", Severity.Success);
            await LoadEntries();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }
}
