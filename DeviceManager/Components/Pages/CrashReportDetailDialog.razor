@* Crash report detail dialog *@
<MudDialog>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Device ID</MudText>
                <MudText Style="font-family:monospace">@Report.DeviceId</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Report ID</MudText>
                <MudText>#@Report.ReportId</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">App Version</MudText>
                <MudText>@(Report.AppVersion ?? "-")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">OS Version</MudText>
                <MudText>@(Report.OsVersion ?? "-")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Occurred At</MudText>
                <MudText>@Report.OccurredAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</MudText>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Received At</MudText>
                <MudText>@Report.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</MudText>
            </MudItem>

            <MudItem xs="12">
                <MudDivider />
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Exception Type</MudText>
                <MudChip T="string" Color="Color.Error" Size="Size.Small">@Report.ExceptionType</MudChip>
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Message</MudText>
                <MudText>@Report.Message</MudText>
            </MudItem>

            @if (!string.IsNullOrEmpty(Report.InnerException))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Inner Exception</MudText>
                    <MudText>@Report.InnerException</MudText>
                </MudItem>
            }

            @if (!string.IsNullOrEmpty(Report.StackTrace))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Stack Trace</MudText>
                    <MudPaper Outlined="true" Class="pa-2" Style="max-height:240px;overflow-y:auto">
                        <pre style="font-size:0.72rem;white-space:pre-wrap;word-break:break-all;margin:0">@Report.StackTrace</pre>
                    </MudPaper>
                </MudItem>
            }

            @if (Report.AdditionalData is { Count: > 0 })
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Additional Data</MudText>
                    <MudSimpleTable Dense="true" Elevation="0">
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kv in Report.AdditionalData)
                            {
                                <tr>
                                    <td style="font-family:monospace;font-size:0.75rem">@kv.Key</td>
                                    <td style="font-size:0.75rem">@kv.Value</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>
